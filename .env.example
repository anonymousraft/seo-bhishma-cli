# LLM Provider Configuration
SEO_BHISHMA_LLM_PROVIDER=openai          # openai | anthropic
SEO_BHISHMA_LLM_MODEL=gpt-4o             # Model name for the selected provider

# API Keys
SEO_BHISHMA_OPENAI_API_KEY=
SEO_BHISHMA_ANTHROPIC_API_KEY=

# Google Search Console
SEO_BHISHMA_GSC_CREDENTIALS_PATH=        # Path to Google OAuth credentials JSON
SEO_BHISHMA_GSC_TOKEN_PATH=token.pickle   # Path to cached token

# Captcha Service (optional)
SEO_BHISHMA_CAPTCHA_SERVICE=              # 2captcha | anti-captcha
SEO_BHISHMA_CAPTCHA_API_KEY=

# NLP
SEO_BHISHMA_SPACY_MODEL=en_core_web_sm

# Logging
SEO_BHISHMA_LOG_LEVEL=INFO
